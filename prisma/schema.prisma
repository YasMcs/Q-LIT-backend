generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Required Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String?   // 'teacher' o 'student'
  accounts      Account[]
  sessions      Session[]

  // --- Q-LIT Relations ---
  classroomsCreated Classroom[]  @relation("TeacherClassrooms")
  enrollments       Enrollment[]
  submissions       Submission[]
  practiceErrorLogs PracticeErrorLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Q-LIT DOMAIN MODELS
// ==========================================

model Classroom {
  id          String   @id @default(cuid())
  name        String
  group       String?
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  isArchived  Boolean  @default(false)
  
  teacherId   String
  teacher     User     @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)

  enrollments Enrollment[]
  practices   Practice[]

  @@index([teacherId])
  @@index([isArchived])
}

model Enrollment {
  id          String   @id @default(cuid())
  joinedAt    DateTime @default(now())
  isArchived  Boolean  @default(false)
  role        String   @default("student") // 'student' o 'co_teacher'

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([userId, classroomId])
  @@index([classroomId])
  @@index([userId])
}

model Practice {
  id                  String   @id @default(cuid())
  title               String
  description         String?
  requiredFunctions   Json?    // ["SELECT", "WHERE"]
  totalPoints         Int      @default(100)
  createdAt           DateTime @default(now())
  deadline            DateTime?
  closeLateSubmissions Boolean  @default(false)

  classroomId         String
  classroom           Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  checklistItems      ChecklistItem[]
  submissions         Submission[]
  errorLogs           PracticeErrorLog[]

  @@index([classroomId])
}

model ChecklistItem {
  id          String   @id @default(cuid())
  criterion   String

  practiceId  String
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  evaluations ChecklistEvaluation[]

  @@index([practiceId])
}

model Submission {
  id                  String   @id @default(cuid())
  studentSqlCode      String?  @db.Text
  generatedStatement  String?  @db.Text // El enunciado único generado por la IA
  setupSql            String?  @db.Text // El DML generado por la IA para inyectar en la DB
  executionResult     String?  @db.Text // El resultado en formato JSON de la tabla (columnas y filas)
  reviewStatus        String   @default("en_progreso") // en_progreso, pendiente, calificada, no_entregada
  currentStep         Int      @default(0) // El paso actual en el que se encuentra el estudiante
  finalGrade          Float?   // Calificación final asignada libremente por el docente
  submittedAt         DateTime @default(now())

  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceId          String
  practice            Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  evaluations         ChecklistEvaluation[]
  steps               SubmissionStep[]

  @@unique([userId, practiceId]) // Un alumno tiene 1 submission por práctica
  @@index([practiceId])
  @@index([userId])
}

model ChecklistEvaluation {
  id                String   @id @default(cuid())
  aiComplies        Boolean? // cumple_ia
  teacherComplies   Boolean? // cumple_docente

  submissionId      String
  submission        Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  checklistItemId   String
  checklistItem     ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([submissionId, checklistItemId])
}

model SubmissionStep {
  id                String   @id @default(cuid())
  stepIndex         Int
  passedAtFirstTry  Boolean? // true si lo logró en el primer intento, false si falló el primer intento
  attemptsCount     Int      @default(0)
  finalSqlCode      String?  @db.Text // El código con el que superó el paso
  errorLogs         Json?    @default("[]") // Historial de errores: [{ query: "...", error: "...", timestamp: "..." }]
  completed         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  submissionId      String
  submission        Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, stepIndex])
  @@index([submissionId])
}

model PracticeErrorLog {
  id              String   @id @default(cuid())
  errorCategory   String   // ej. "Error de Sintaxis", "Tabla inexistente"
  sqlConcept      String   // ej. "JOIN", "WHERE", "General"
  originalMessage String?  @db.Text
  createdAt       DateTime @default(now())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceId      String
  practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([practiceId])
}
