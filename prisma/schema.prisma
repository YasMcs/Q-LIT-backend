generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Required Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String?   // 'teacher' o 'student'
  accounts      Account[]
  sessions      Session[]

  // --- Q-LIT Relations ---
  classroomsCreated Classroom[]  @relation("TeacherClassrooms")
  enrollments       Enrollment[]
  submissions       Submission[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Q-LIT DOMAIN MODELS
// ==========================================

model Classroom {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  
  teacherId   String
  teacher     User     @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)

  enrollments Enrollment[]
  practices   Practice[]
}

model Enrollment {
  id          String   @id @default(cuid())
  joinedAt    DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([userId, classroomId])
}

model Practice {
  id                  String   @id @default(cuid())
  title               String
  description         String?
  requiredFunctions   Json?    // ["SELECT", "WHERE"]
  totalPoints         Int      @default(100)
  createdAt           DateTime @default(now())
  deadline            DateTime?

  classroomId         String
  classroom           Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  checklistItems      ChecklistItem[]
  submissions         Submission[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  criterion   String
  maxPoints   Int

  practiceId  String
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  evaluations ChecklistEvaluation[]
}

model Submission {
  id                  String   @id @default(cuid())
  studentSqlCode      String?  @db.Text
  generatedStatement  String?  @db.Text // El enunciado único generado por la IA
  reviewStatus        String   @default("pendiente") // pendiente, calificada, no_entregada
  submittedAt         DateTime @default(now())

  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceId          String
  practice            Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  evaluations         ChecklistEvaluation[]

  @@unique([userId, practiceId]) // Un alumno tiene 1 submission por práctica
}

model ChecklistEvaluation {
  id                String   @id @default(cuid())
  aiComplies        Boolean? // cumple_ia
  teacherComplies   Boolean? // cumple_docente

  submissionId      String
  submission        Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  checklistItemId   String
  checklistItem     ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([submissionId, checklistItemId])
}
